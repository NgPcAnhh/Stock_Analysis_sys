# ============================================
# Database
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/stock_market
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/stock_market

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ============================================
# App
# ============================================
APP_NAME=Stock Market API
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# External APIs
# ============================================
SSI_IBOARD_BASE_URL=https://iboard-query.ssi.com.vn/v2
SIMPLIZE_WS_URL=wss://stream2.simplize.vn/ws

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# Server
# ============================================
HOST=0.0.0.0
PORT=8000
WORKERS=4
